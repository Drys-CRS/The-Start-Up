# OpenRouter — generates the personalized Bottleneck Report (server-side only)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# Monday.com — personal API token (Profile > Developers > My Access Tokens)
MONDAY_API_TOKEN=xxxxxxxx

# Board IDs are pre-filled to the boards already created in your account.
# Override only if you recreate the boards.
MONDAY_LEADS_BOARD_ID=18419074343
MONDAY_SCOPE_BOARD_ID=18419074490
